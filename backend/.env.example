APP_ENV=development
APP_DEBUG=false
APP_PROJECT_NAME=Nutrition Assistant API
APP_API_V1_PREFIX=/api/v1
APP_SECRET_KEY=change-this-to-a-long-random-secret-change-this
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=15
APP_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutrition_app
APP_DATABASE_ECHO=false
APP_REDIS_URL=redis://localhost:6379/0
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
APP_OPENAI_API_KEY=
APP_OPENAI_MODEL=gpt-4.1-mini
APP_S3_ENDPOINT_URL=http://localhost:9000
APP_S3_REGION=us-east-1
APP_S3_BUCKET=nutrition-assets
APP_S3_ACCESS_KEY_ID=minioadmin
APP_S3_SECRET_ACCESS_KEY=minioadmin
APP_S3_USE_SSL=false
APP_MAX_UPLOAD_BYTES=5242880
APP_ALLOWED_UPLOAD_MIME=image/jpeg,image/png,image/webp
APP_RATE_LIMIT_PER_MINUTE=120
